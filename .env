# ─── Frontend env vars (must start with VITE_) ───────────────────────────────
#
# Use a RELATIVE path (/api) — NOT an absolute URL.
# Vite's dev proxy intercepts /api on the same origin (localhost:5173).
# In production, point your reverse-proxy (nginx) to forward /api → http://localhost:3001.

VITE_API_URL=/api